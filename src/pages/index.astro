---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Loïck Legallais — UI / UX Designer Freelance</title>
  <meta name="description" content="Designer UI/UX Freelance basé à Lyon. Je crée des interfaces pensées pour vos objectifs." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet" />
</head>
<body>

<!-- ============================================================
     1. MENU
     Figma: top 109px (below header bar), px 16px, container teal
     border-radius: 20px 20px 0 0 (top only)
     ============================================================ -->
<header class="menu-wrap">
  <div class="menu">
    <!-- Logo + Nom + Status -->
    <div class="menu-brand">
      <div class="menu-logo" aria-hidden="true">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="48" height="48" rx="10" fill="white" fill-opacity="0.15"/>
          <text x="24" y="31" text-anchor="middle" font-family="Inter" font-size="20" font-weight="600" fill="white">L</text>
        </svg>
      </div>
      <div class="menu-identity">
        <span class="menu-name">Loïck Legallais</span>
        <span class="menu-status">
          <span class="menu-dot" aria-hidden="true"></span>
          Freelance basé à Lyon
        </span>
      </div>
    </div>

    <!-- Nav links in pill -->
    <nav class="menu-nav" aria-label="Navigation principale">
      <a href="/projets">Work</a>
      <a href="/a-propos">A propos</a>
      <a href="/ressources">Ressources</a>
    </nav>

    <!-- CTA -->
    <a href="mailto:legallais.loick@gmail.com" class="menu-cta">Contact</a>
  </div>
</header>


<!-- ============================================================
     2. HERO
     Figma: px 16px, container teal 671px tall, rounded bottom
     Content: badge + h1 76px + subtitle 20px, centered
     Stickers: etoile (left 149px top 227px), eyes (right ~170px top ~115px), peace (bottom center)
     ============================================================ -->
<section class="hero-wrap">
  <div class="hero">
    <!-- Sticker étoile -->
    <img src="/images/stickers/etoile.svg" alt="" class="sticker sticker-etoile" aria-hidden="true" />
    <!-- Sticker eyes (deux yeux côte à côte dans Figma) -->
    <img src="/images/stickers/eyes.svg" alt="" class="sticker sticker-eyes" aria-hidden="true" />
    <!-- Sticker peace -->
    <img src="/images/stickers/peace.svg" alt="" class="sticker sticker-peace" aria-hidden="true" />

    <div class="hero-content">
      <!-- Badge disponibilité -->
      <div class="hero-badge">
        <span class="hero-badge-dot" aria-hidden="true"></span>
        UI / UX Designer Freelance - Disponible
      </div>

      <!-- Titre principal — 76px dans Figma -->
      <h1 class="hero-title">Des interfaces pensées pour vos objectifs</h1>

      <!-- Sous-titre — 20px, 655px wide, opacity 0.8 -->
      <p class="hero-subtitle">
        Le design ne doit plus être seulement esthétique mais répondre à des objectifs clairs. En vous accompagnant, je me base sur des datas solides pour proposer une expérience utilisateur réussie.
      </p>
    </div>
  </div>
</section>


<!-- ============================================================
     3. PROJETS
     Figma: padding 64px 80px, 2 rows × 3 cols, gap 40px
     Row 1: LikeWatt (wide 655px) + SBG + Wikit (flex 1)
     Row 2: Manerty (flex 1) + Los Primos (wide 655px) + Le Spot (flex 1)
     Each project: image + title 24px + desc 16px + tags
     ============================================================ -->
<section class="projets">
  <div class="projets-header">
    <h2 class="section-title">Des projets qui ont du sens.</h2>
    <a href="/projets" class="section-link">Tout découvrir</a>
  </div>

  <div class="projets-grid">
    <!-- ROW 1 -->
    <div class="projets-row">
      {projetsRow1.map((p) => (
        <a
          href={`/projets/${p.slug}`}
          class={`projet-card ${p.wide ? 'projet-card--wide' : ''}`}
        >
          <div class="projet-card-img" style={`background-color: ${p.bgColor}`}></div>
          <div class="projet-card-content">
            <div class="projet-card-text">
              <span class="projet-card-title">{p.title}</span>
              <span class="projet-card-desc">{p.description}</span>
            </div>
            <div class="projet-card-tags">
              {p.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- ROW 2 -->
    <div class="projets-row">
      {projetsRow2.map((p) => (
        <a
          href={`/projets/${p.slug}`}
          class={`projet-card ${p.wide ? 'projet-card--wide' : ''}`}
        >
          <div class="projet-card-img" style={`background-color: ${p.bgColor}`}></div>
          <div class="projet-card-content">
            <div class="projet-card-text">
              <span class="projet-card-title">{p.title}</span>
              <span class="projet-card-desc">{p.description}</span>
            </div>
            <div class="projet-card-tags">
              {p.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>


<!-- ============================================================
     4. MÉTHODOLOGIE
     Figma: outer padding 28px 16px, inner bg #ebf1f1 border-radius 20px
     Inner padding: 64px 80px, gap 64px
     3 cards blanc, height ~428px, padding 28px, justify-between
     Title (Analyser etc.) en haut, texte gris en bas
     ============================================================ -->
<section class="methodo-wrap">
  <div class="methodo">
    <h2 class="section-title">Une méthodologie efficace et sur mesure.</h2>
    <div class="methodo-grid">
      {methodo.map((step) => (
        <div class="methodo-card">
          <span class="methodo-card-title">{step.title}</span>
          <p class="methodo-card-text">{step.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ============================================================
     5. ILS ME FONT CONFIANCE
     Figma: padding 64px 80px, titre centré 46px
     Grille: row 1 = 5 logos flex-1, row 2 = 4 logos 270px fixed
     Chaque cellule: bg white, border #ebf1f1, padding 64px 28px
     ============================================================ -->
<section class="clients">
  <h2 class="section-title clients-title">Ils me font confiance</h2>
  <div class="clients-grid">
    <!-- Row 1: 5 logos -->
    <div class="clients-row">
      {logosRow1.map((i) => (
        <div class="client-cell">
          <div class="client-logo-placeholder" aria-label={`Client ${i}`}>
            <span class="client-logo-text">Logo {i}</span>
          </div>
        </div>
      ))}
    </div>
    <!-- Row 2: 4 logos (fixed 270px each) -->
    <div class="clients-row clients-row--small">
      {logosRow2.map((i) => (
        <div class="client-cell client-cell--fixed">
          <div class="client-logo-placeholder" aria-label={`Client ${i}`}>
            <span class="client-logo-text">Logo {i}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ============================================================
     6. RESSOURCES
     Figma: padding 64px 60px, titre left + "Tout découvrir" underline right
     3 cards flex-1: image 300px + tag + title 24px
     ============================================================ -->
<section class="ressources">
  <div class="ressources-header">
    <h2 class="section-title">Quelques ressources à disposition</h2>
    <a href="/ressources" class="section-link">Tout découvrir</a>
  </div>
  <div class="ressources-grid">
    {ressources.map((r) => (
      <a href={`/ressources/${r.slug}`} class="ressource-card">
        <div class="ressource-card-img"></div>
        <span class="tag">{r.tag}</span>
        <span class="ressource-card-title">{r.title}</span>
      </a>
    ))}
  </div>
</section>


<!-- ============================================================
     7. FOOTER
     Figma: padding 24px 60px, border-top #f4f2fd
     Left: logo 48px + nav links gap 40px
     Right: email + LinkedIn pill + Figma pill
     ============================================================ -->
<footer class="footer">
  <div class="footer-left">
    <div class="footer-logo" aria-hidden="true">
      <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
        <rect width="48" height="48" rx="10" fill="#075056"/>
        <text x="24" y="31" text-anchor="middle" font-family="Inter" font-size="20" font-weight="600" fill="white">L</text>
      </svg>
    </div>
    <nav class="footer-nav" aria-label="Navigation pied de page">
      <a href="/projets">Projets</a>
      <a href="/a-propos">A propos</a>
      <a href="/ressources">Ressources</a>
      <a href="mailto:legallais.loick@gmail.com">Contact</a>
    </nav>
  </div>
  <div class="footer-right">
    <a href="mailto:legallais.loick@gmail.com" class="footer-email">legallais.loick@gmail.com</a>
    <div class="footer-socials">
      <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="footer-social">Linkedin</a>
      <a href="https://figma.com" target="_blank" rel="noopener noreferrer" class="footer-social">Figma</a>
    </div>
  </div>
</footer>


<style>
  /* ============================================================
     DESIGN TOKENS — V2
     Fluid unit: 1512px artboard
     ============================================================ */
  :root {
    --vw: clamp(360px, 100vw, 1800px);
    --unit: calc(var(--vw) / 1512);

    /* Palette */
    --teal:         #075056;
    --teal-mid:     #206267;
    --teal-border:  #397378;
    --cream:        #ebf1f1;
    --white:        #ffffff;
    --dark:         #16232b;
    --muted:        #737a7a;
    --purple:       #31243d;
    --dot-green:    #4fe89b;
    --border-light: #f4f2fd;
    --border-cream: #ebf1f1;

    /* Font */
    --font: 'Inter', system-ui, sans-serif;

    /* Fluid sizes */
    --t-xs:   max(10px, calc(12 * var(--unit)));
    --t-sm:   max(12px, calc(14 * var(--unit)));
    --t-base: max(14px, calc(16 * var(--unit)));
    --t-md:   max(16px, calc(20 * var(--unit)));
    --t-lg:   max(20px, calc(24 * var(--unit)));
    --t-xl:   max(28px, calc(46 * var(--unit)));
    --t-hero: clamp(36px, calc(76 * var(--unit)), 76px);

    /* Spacing */
    --s-1:  calc(4  * var(--unit));
    --s-2:  calc(8  * var(--unit));
    --s-3:  calc(12 * var(--unit));
    --s-4:  calc(16 * var(--unit));
    --s-5:  calc(20 * var(--unit));
    --s-6:  calc(24 * var(--unit));
    --s-7:  calc(28 * var(--unit));
    --s-10: calc(40 * var(--unit));
    --s-12: calc(48 * var(--unit));
    --s-16: calc(64 * var(--unit));
    --s-20: calc(80 * var(--unit));

    /* Layout */
    --outer-pad: 16px;
    --inner-pad-x: clamp(32px, calc(80 * var(--unit)), 80px);
    --inner-pad-y: clamp(32px, calc(64 * var(--unit)), 64px);

    /* Radii */
    --r-sm: 8px;
    --r-lg: 20px;

    /* Ease */
    --ease: cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Reset */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { -webkit-font-smoothing: antialiased; scroll-behavior: smooth; }
  body { font-family: var(--font); color: var(--dark); background: var(--white); overflow-x: hidden; }
  img { display: block; max-width: 100%; }
  a { color: inherit; text-decoration: none; }
  ul, li { list-style: none; }

  /* Tag utility */
  .tag {
    display: inline-flex;
    align-items: center;
    padding: 8px 16px;
    background: var(--cream);
    color: var(--dark);
    font-size: var(--t-xs);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-radius: var(--r-sm);
    white-space: nowrap;
  }

  .section-title {
    font-size: var(--t-xl);
    font-weight: 400;
    line-height: 1.1;
    color: var(--dark);
  }

  .section-link {
    font-size: var(--t-base);
    color: var(--dark);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.2s;
  }
  .section-link:hover { opacity: 0.6; }

  /* ============================================================
     MENU
     ============================================================ */
  .menu-wrap {
    position: sticky;
    top: 0;
    z-index: 100;
    padding: var(--outer-pad) var(--outer-pad) 0;
    background: var(--white);
  }

  .menu {
    background: var(--teal);
    border-bottom: 1px solid var(--teal-border);
    border-radius: var(--r-lg) var(--r-lg) 0 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: calc(20 * var(--unit));
  }

  .menu-brand {
    display: flex;
    align-items: center;
    gap: calc(16 * var(--unit));
  }

  .menu-logo { width: 48px; height: 48px; flex-shrink: 0; }

  .menu-identity {
    display: flex;
    flex-direction: column;
    gap: 4px;
    width: calc(165 * var(--unit));
  }

  .menu-name {
    font-size: var(--t-base);
    font-weight: 500;
    color: var(--white);
    line-height: 1.2;
  }

  .menu-status {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: var(--t-sm);
    color: #cddcdd;
    line-height: 1.2;
  }

  .menu-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--dot-green);
    flex-shrink: 0;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .menu-nav {
    display: flex;
    align-items: center;
    gap: calc(40 * var(--unit));
    background: var(--teal-mid);
    padding: calc(16 * var(--unit)) calc(24 * var(--unit));
    border-radius: calc(12 * var(--unit));
    font-size: var(--t-base);
    color: var(--white);
  }

  .menu-nav a { transition: opacity 0.2s; }
  .menu-nav a:hover { opacity: 0.7; }

  .menu-cta {
    background: var(--white);
    color: var(--dark);
    font-size: var(--t-base);
    padding: calc(16 * var(--unit)) calc(24 * var(--unit));
    border-radius: calc(12 * var(--unit));
    transition: background 0.2s;
  }
  .menu-cta:hover { background: var(--cream); }

  /* ============================================================
     HERO
     ============================================================ */
  .hero-wrap {
    padding: 0 var(--outer-pad);
  }

  .hero {
    position: relative;
    height: calc(671 * var(--unit));
    min-height: 400px;
    background: linear-gradient(135deg, #0a767f 0%, var(--teal) 60%);
    border-radius: 0 0 var(--r-lg) var(--r-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: calc(100 * var(--unit)) calc(80 * var(--unit)) calc(120 * var(--unit));
    overflow: hidden;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: calc(16 * var(--unit));
    max-width: calc(887 * var(--unit));
    text-align: center;
    position: relative;
    z-index: 2;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: calc(12 * var(--unit));
    background: var(--teal-mid);
    color: var(--white);
    font-size: var(--t-base);
    padding: 8px 16px;
    border-radius: var(--r-sm);
  }

  .hero-badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--dot-green);
    flex-shrink: 0;
    animation: pulse 2s ease-in-out infinite;
  }

  .hero-title {
    font-size: var(--t-hero);
    font-weight: 400;
    line-height: 1.1;
    color: var(--white);
    letter-spacing: -0.01em;
  }

  .hero-subtitle {
    font-size: clamp(15px, calc(20 * var(--unit)), 20px);
    font-weight: 400;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.8);
    max-width: calc(655 * var(--unit));
  }

  /* Stickers */
  .sticker {
    position: absolute;
    pointer-events: none;
    z-index: 3;
  }

  /* Figma: left 149px, top 227px, size ~109px, rotate 19.32deg */
  .sticker-etoile {
    left: calc(149 * var(--unit));
    top: calc(227 * var(--unit));
    width: calc(90 * var(--unit));
    transform: rotate(19.32deg);
  }

  /* Figma: left ~1217px, top ~115px, size ~117px, rotate -6.11deg */
  .sticker-eyes {
    right: calc(180 * var(--unit));
    top: calc(115 * var(--unit));
    width: calc(117 * var(--unit));
    transform: rotate(-6.11deg);
  }

  /* Figma: bottom ~8.6% from bottom, centered ~52-59% from left */
  .sticker-peace {
    left: 52%;
    bottom: calc(58 * var(--unit));
    width: calc(80 * var(--unit));
    transform: rotate(24.81deg);
  }

  /* ============================================================
     PROJETS
     ============================================================ */
  .projets {
    padding: var(--inner-pad-y) var(--inner-pad-x);
    display: flex;
    flex-direction: column;
    gap: var(--s-16);
  }

  .projets-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
  }

  .projets-grid {
    display: flex;
    flex-direction: column;
    gap: var(--s-10);
  }

  .projets-row {
    display: flex;
    align-items: flex-start;
    gap: var(--s-10);
  }

  /* Default card: flex 1 */
  .projet-card {
    flex: 1 0 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-5);
    cursor: pointer;
    text-decoration: none;
  }

  /* Wide card: 655px fixed — Figma row1 col1, row2 col2 */
  .projet-card--wide {
    flex: 0 0 calc(655 * var(--unit));
    max-width: calc(655 * var(--unit));
  }

  /* Image area */
  .projet-card-img {
    width: 100%;
    border-radius: var(--r-sm);
    aspect-ratio: 16 / 11;
    overflow: hidden;
    transition: transform 0.4s var(--ease);
  }

  .projet-card:hover .projet-card-img {
    transform: scale(1.02);
  }

  /* Wide card: specific aspect ratio from Figma (424/300 ≈ 1.41) */
  .projet-card--wide .projet-card-img {
    aspect-ratio: 424 / 300;
  }

  /* Content below image */
  .projet-card-content {
    display: flex;
    flex-direction: column;
    gap: var(--s-6);
  }

  .projet-card-text {
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }

  .projet-card-title {
    font-size: var(--t-lg);
    font-weight: 400;
    color: var(--dark);
    line-height: 1.3;
    transition: color 0.2s;
  }

  .projet-card:hover .projet-card-title {
    color: var(--teal);
  }

  .projet-card-desc {
    font-size: var(--t-base);
    color: var(--muted);
    line-height: 1.5;
  }

  .projet-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-5);
  }

  /* ============================================================
     MÉTHODOLOGIE
     ============================================================ */
  .methodo-wrap {
    padding: calc(28 * var(--unit)) var(--outer-pad);
  }

  .methodo {
    background: var(--cream);
    border-radius: var(--r-lg);
    padding: var(--inner-pad-y) var(--inner-pad-x);
    display: flex;
    flex-direction: column;
    gap: var(--s-16);
  }

  .methodo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-10);
  }

  .methodo-card {
    background: var(--white);
    border-radius: var(--r-sm);
    padding: calc(28 * var(--unit));
    height: calc(428 * var(--unit));
    min-height: 200px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: transform 0.3s var(--ease);
  }

  .methodo-card:hover {
    transform: translateY(-4px);
  }

  .methodo-card-title {
    font-size: var(--t-lg);
    font-weight: 500;
    color: var(--purple);
    line-height: 1.5;
  }

  .methodo-card-text {
    font-size: clamp(14px, calc(20 * var(--unit)), 20px);
    font-weight: 400;
    color: var(--muted);
    line-height: 1.5;
  }

  /* ============================================================
     CLIENTS
     ============================================================ */
  .clients {
    padding: var(--inner-pad-y) var(--inner-pad-x);
    display: flex;
    flex-direction: column;
    gap: var(--s-16);
  }

  .clients-title {
    text-align: center;
  }

  .clients-grid {
    display: flex;
    flex-direction: column;
  }

  .clients-row {
    display: flex;
    align-items: stretch;
  }

  /* Row 1: 5 cells flex-1 */
  .client-cell {
    flex: 1 0 0;
    min-width: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--s-16) calc(28 * var(--unit));
    border: 1px solid var(--border-cream);
    background: var(--white);
    transition: background 0.2s;
  }

  .client-cell:hover {
    background: var(--cream);
  }

  /* Row 2: 4 cells fixed 270.4px */
  .client-cell--fixed {
    flex: 0 0 calc(270.4 * var(--unit));
    max-width: calc(270.4 * var(--unit));
  }

  .client-logo-placeholder {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .client-logo-text {
    font-size: var(--t-sm);
    color: var(--muted);
    font-weight: 500;
    /* Replace with real <img> logo */
  }

  /* ============================================================
     RESSOURCES
     ============================================================ */
  .ressources {
    padding: var(--inner-pad-y) clamp(32px, calc(60 * var(--unit)), 60px);
    display: flex;
    flex-direction: column;
    gap: var(--s-16);
  }

  .ressources-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
  }

  .ressources-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-10);
  }

  .ressource-card {
    display: flex;
    flex-direction: column;
    gap: var(--s-5);
    cursor: pointer;
  }

  .ressource-card-img {
    width: 100%;
    height: calc(300 * var(--unit));
    min-height: 160px;
    border-radius: var(--r-sm);
    background: #d9d9d9;
    overflow: hidden;
    transition: transform 0.4s var(--ease);
  }

  .ressource-card:hover .ressource-card-img {
    transform: scale(1.02);
  }

  .ressource-card-title {
    font-size: var(--t-lg);
    font-weight: 400;
    color: var(--purple);
    line-height: 1.3;
  }

  /* ============================================================
     FOOTER
     ============================================================ */
  .footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: calc(24 * var(--unit)) clamp(32px, calc(60 * var(--unit)), 60px);
    border-top: 1px solid var(--border-light);
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: var(--s-12);
  }

  .footer-logo { flex-shrink: 0; }

  .footer-nav {
    display: flex;
    align-items: center;
    gap: var(--s-10);
    font-size: var(--t-base);
    color: var(--dark);
  }

  .footer-nav a { transition: opacity 0.2s; }
  .footer-nav a:hover { opacity: 0.6; }

  .footer-right {
    display: flex;
    align-items: center;
    gap: var(--s-12);
  }

  .footer-email {
    font-size: var(--t-base);
    color: var(--dark);
    transition: opacity 0.2s;
  }
  .footer-email:hover { opacity: 0.6; }

  .footer-socials {
    display: flex;
    align-items: center;
    gap: var(--s-12);
  }

  .footer-social {
    background: var(--cream);
    color: var(--dark);
    font-size: var(--t-xs);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 8px 16px;
    border-radius: var(--r-sm);
    transition: background 0.2s;
  }
  .footer-social:hover { background: #d1dede; }

  /* ============================================================
     MOBILE (≤ 768px)
     ============================================================ */
  @media (max-width: 768px) {
    /* Menu */
    .menu-wrap { padding: 12px 12px 0; }
    .menu { padding: 12px 16px; }
    .menu-identity { display: none; }
    .menu-nav { gap: 20px; padding: 10px 14px; font-size: 14px; }
    .menu-cta { padding: 10px 14px; font-size: 14px; }

    /* Hero */
    .hero-wrap { padding: 0 12px; }
    .hero { height: auto; min-height: 80vh; padding: 60px 24px 80px; }
    .hero-title { font-size: clamp(28px, 8vw, 48px); }
    .hero-subtitle { font-size: 16px; }
    .sticker { display: none; }

    /* Projets */
    .projets { padding: 40px 20px; gap: 40px; }
    .projets-row { flex-direction: column; }
    .projet-card, .projet-card--wide { flex: none; width: 100%; max-width: 100%; }

    /* Methodo */
    .methodo-wrap { padding: 20px 12px; }
    .methodo { padding: 40px 24px; }
    .methodo-grid { grid-template-columns: 1fr; gap: 16px; }
    .methodo-card { height: auto; min-height: 160px; padding: 24px; gap: 24px; }

    /* Clients */
    .clients { padding: 40px 20px; }
    .clients-row { flex-wrap: wrap; }
    .client-cell, .client-cell--fixed { flex: 1 0 45%; max-width: none; padding: 28px 16px; }

    /* Ressources */
    .ressources { padding: 40px 20px; }
    .ressources-grid { grid-template-columns: 1fr; gap: 32px; }
    .ressource-card-img { height: 200px; }

    /* Footer */
    .footer { flex-direction: column; align-items: flex-start; gap: 28px; padding: 32px 20px; }
    .footer-left { flex-direction: column; align-items: flex-start; gap: 20px; }
    .footer-nav { flex-wrap: wrap; gap: 16px; }
    .footer-right { flex-direction: column; align-items: flex-start; gap: 16px; }
    .footer-socials { gap: 12px; }
  }
</style>

</body>
