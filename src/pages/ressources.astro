---
import Layout from '../layouts/Layout.astro';
import ResourcesSection from '../components/ResourcesSection.astro';
---

<Layout title="Ressources — Loïck Legallais">
 <section class="ressources-hero">
  <div class="ressources-hero__inner">
    <h1 class="ressources-hero__title display">RESSOURCES</h1>
    <img
  src="/images/stickers/peace.svg"
  alt=""
  class="sticker sticker--etoile"
  data-parallax-speed="0.3"
  data-rotation="19.32"
  aria-hidden="true"
/>
<img
  src="/images/stickers/eyes.svg"
  alt=""
  class="sticker sticker--peace"
  data-parallax-speed="0.3"
  data-rotation="19.32"
  aria-hidden="true"
/>
  </div>
</section>
<ResourcesSection showTitle={false} />
</Layout>

<style>
  /* ============================================
     HERO — lime band with big title
     ============================================ */
  .ressources-hero {
    background-color: var(--color-lime);
    padding: calc(250 * var(--unit)) var(--container-padding) calc(150 * var(--unit));
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
  }

  .ressources-hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: calc(1392 * var(--unit));
  }

  .ressources-hero__title {
    /* Fluid: 48px mobile → 102px desktop */
    font-size: var(--text-archive-hero);
    color: var(--color-aubergine);
    text-align: center;
    letter-spacing: 0.02em;
    margin: 0;
    width: 100%;
  }

  /* ============================================
     ARCHIVE — filters + grid
     ============================================ */
  .projects-archive {
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
    padding: var(--space-30) var(--container-padding);
    background: var(--color-white);
  }

  .sticker {
    position: absolute;
    pointer-events: none;
    z-index: 5;
    height: auto;
    will-change: transform;
  }

  /* Etoile — TOP LEFT zone, around 1/4 in from the left */
  .sticker--etoile {
    top: 18%;
    left: 22%;
    width: calc(90 * var(--unit));
    transform: rotate(19.32deg);
  }


  /* Peace — BOTTOM RIGHT zone */
  .sticker--peace {
    bottom: 18%;
    right: 18%;
    width: calc(120 * var(--unit));
    transform: rotate(-20deg);
  }
  /* Filters */
  .filters {
    display: none;
    gap: calc(28 * var(--unit));
    align-items: center;
    flex-wrap: wrap;
  }

  .filter-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
    border: 1px solid var(--color-aubergine);
    border-radius: var(--radius-sm);
    background: var(--color-white);
    color: #000;
    /* Fluid: 14px mobile → 16px desktop */
    font-size: var(--text-filter);
    font-family: var(--font-body);
    cursor: pointer;
    transition: background var(--transition-base), color var(--transition-base);
  }

  .filter-btn:hover {
    background: var(--color-aubergine);
    color: var(--color-white);
  }

  .filter-btn.is-active {
    background: var(--color-aubergine);
    color: var(--color-white);
  }

  /* Cards grid — 2 cols desktop, 1 col mobile */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-16) var(--space-10);
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    text-decoration: none;
    color: var(--color-aubergine);
    transition: transform var(--transition-base);
  }

  .project-card:hover {
    transform: translateY(-4px);
  }

  .project-card__image {
    width: 100%;
    aspect-ratio: 451 / 300;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-placeholder);
  }

  .project-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out);
  }

  .project-card:hover .project-card__image img {
    transform: scale(1.04);
  }

  .project-card__placeholder {
    width: 100%;
    height: 100%;
  }

  .project-card__tag {
    color: var(--color-aubergine);
    align-self: flex-start;
  }

  .project-card__title {
    font-family: var(--font-body);
    /* Fluid: 18px mobile → 24px desktop */
    font-size: var(--text-card-title);
    font-weight: 500;
    line-height: 1.2;
    margin: 0;
  }

  /* ============================================
     MOBILE
     ============================================ */
  @media (max-width: 768px) {
    .ressources-hero {
      padding: 140px var(--container-padding) 60px;
      min-height: 350px;
    }

    .projects-archive {
      gap: 64px;
      padding: 60px var(--container-padding);
    }

    .filters {
      gap: 28px;
    }

    .filter-btn {
      padding: 16px;
      border-radius: 16px;
    }

    .cards-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .project-card {
      gap: 20px;
    }

    .project-card__image {
      border-radius: 20px;
    }

    .sticker--etoile {
      top: 22%;
      left: 8%;
      right: auto;
      width: 70px;
    }

    .sticker--peace {
      bottom: 2%;
      right: 8%;
      left: auto;
      width: 65px;
    }
  }
</style>
