---
import Layout from '../layouts/LayoutV2.astro';

// Liste des ressources — ajoute des entrées ici pour en avoir plus.
// La grille s'organise automatiquement par lignes de 3.
const ressources = [
  {
    tag: 'Plugin Figma',
    title: 'WebP Manager',
    url: 'https://www.figma.com/community/plugin/1587802543036369275/webp-manager-rename-resize-export',
    slug: 'webp-manager',
    image: null, // ex: '/images/ressources/webp-manager.jpg'
  },
  {
    tag: 'Plugin Figma',
    title: 'Template Application (à venir)',
    slug: 'webp-manager-2',
    image: null,
  },
  {
    tag: 'Plugin Figma',
    title: 'Template E-Commerce (à venir)',
    slug: 'webp-manager-3',
    image: null,
  },
];
---

<Layout title="Ressources — Loïck Legallais" description="Quelques ressources, outils et plugins utiles pour le design UI/UX.">

  <!-- HERO — fond blanc, 369px (plus court que les autres pages) -->
  <section class="hero-wrap">
    <div class="hero">
      <div class="hero-content">
        <h1 class="hero-title">Quelques ressources</h1>
        <p class="hero-subtitle">
          Une sélection d'outils, plugins et ressources que j'utilise au quotidien dans mon travail de designer UI/UX.
        </p>
      </div>
    </div>
  </section>

  <!-- GRILLE RESSOURCES — par lignes de 3 -->
  <section class="ressources">
    <div class="ressources-grid">
      {ressources.map((r) => (
        <a href={r.url} target="_blank" rel="noopener noreferrer" class="ressource-card">
          <div class="ressource-card-img">
            {r.image && <img src={r.image} alt={r.title} class="ressource-card-media" />}
          </div>
          <span class="tag">{r.tag}</span>
          <span class="ressource-card-title">{r.title}</span>
        </a>
      ))}
    </div>
  </section>

</Layout>

<style>
  /* HERO — fond blanc, 369px (vs 441px sur projets/a-propos) */
  .hero-wrap { padding: 0 var(--outer-pad); }
  .hero {
    background: var(--white);
    height: calc(369 * var(--unit));
    min-height: 220px;
    padding: calc(100 * var(--unit)) var(--inner-pad-x) calc(64 * var(--unit));
    display: flex;
    align-items: flex-end;
  }
  .hero-content {
    display: flex;
    flex-direction: column;
    gap: calc(16 * var(--unit));
    max-width: calc(887 * var(--unit));
    width: 100%;
  }
  .hero-title {
    font-size: var(--t-hero);
    font-weight: 400;
    line-height: 1.1;
    color: var(--dark);
    letter-spacing: -0.01em;
  }
  .hero-subtitle {
    font-size: clamp(15px, calc(20 * var(--unit)), 20px);
    line-height: 1.5;
    color: var(--muted);
    max-width: calc(655 * var(--unit));
  }

  /* GRILLE RESSOURCES */
  .ressources {
    padding: var(--inner-pad-y) clamp(32px, calc(60 * var(--unit)), 60px);
  }

  /* 3 colonnes — si plus de 3 ressources, ça passe à la ligne automatiquement */
  .ressources-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-10);
  }

  .ressource-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--s-5);
    cursor: pointer;
  }

  .ressource-card-img {
    position: relative;
    width: 100%;
    height: calc(300 * var(--unit));
    min-height: 160px;
    border-radius: var(--r-sm);
    background: #d9d9d9;
    overflow: hidden;
    transition: transform 0.4s var(--ease);
  }

  .ressource-card:hover .ressource-card-img {
    transform: scale(1.02);
  }

  .ressource-card-media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .ressource-card-title {
    font-size: var(--t-lg);
    font-weight: 400;
    color: var(--purple);
    line-height: 1.3;
  }

  /* MOBILE */
  @media (max-width: 768px) {
    .hero-wrap { padding: 0 12px; }
    .hero { height: auto; min-height: 180px; padding: 40px 24px; align-items: flex-start; border: none; }
    .hero-title { font-size: clamp(28px, 8vw, 48px); }
    .hero-subtitle { font-size: 16px; }

    .ressources { padding: 40px 20px; }
    .ressources-grid { grid-template-columns: 1fr; gap: 32px; }
    .ressource-card-img { height: 280px; }
  }
</style>
