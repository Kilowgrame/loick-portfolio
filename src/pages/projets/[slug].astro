---
import Layout from '../../layouts/LayoutV2.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projets');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { data } = project;
---

<Layout title={`${data.title} — Loïck Legallais`} description={data.description}>

  <article class="single">

    <!-- SIDEBAR -->
    <aside class="sidebar">
      <div class="sidebar-inner">
        <a href="/projets" class="sidebar-back">
          <svg width="16" height="10" viewBox="0 0 16 10" fill="none" aria-hidden="true">
            <path d="M5 1L1 5M1 5L5 9M1 5H15" stroke="#16232b" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Retour aux projets</span>
        </a>

        <div class="sidebar-main">
          <div class="sidebar-header">
            <h1 class="sidebar-title">{data.title}</h1>
            {data.fields && data.fields.length > 0 && (
              <div class="sidebar-tags">
                {data.fields.map((f: string) => <span class="tag">{f}</span>)}
              </div>
            )}
            {data.description && <p class="sidebar-desc">{data.description}</p>}
          </div>

          <div class="sidebar-meta">
            {data.metaItems && data.metaItems.map((item: { label: string; value: string }) => (
              <div class="meta-item">
                <div class="meta-item-row">
                  <span class="meta-label">{item.label}</span>
                  <span class="meta-value">{item.value}</span>
                </div>
                <div class="meta-sep"></div>
              </div>
            ))}
            {data.liveUrl && (
              <div class="meta-item">
                <a href={data.liveUrl} target="_blank" rel="noopener noreferrer" class="meta-item-row meta-link">
                  <span class="meta-label">Voir le site</span>
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M7 17L17 7M17 7H7M17 7V17" stroke="#16232b" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
                <div class="meta-sep"></div>
              </div>
            )}
          </div>
        </div>
      </div>
    </aside>

    <!-- CONTENT -->
    <div class="content">
      {data.blocs && data.blocs.map((bloc: any) => {
        if (bloc.type === 'text') return <p class="bloc-text">{bloc.contenu}</p>;
        if (bloc.type === 'text-muted') return <p class="bloc-text bloc-text--muted">{bloc.contenu}</p>;
        if (bloc.type === 'image') return (
          <figure class="bloc-image">
            <img src={bloc.src} alt={bloc.alt ?? ''} loading="lazy" />
            {bloc.legende && <figcaption>{bloc.legende}</figcaption>}
          </figure>
        );
        if (bloc.type === 'video') return (
          <video class="bloc-video" src={bloc.src} poster={bloc.poster} autoplay={bloc.autoplay ?? true} loop={bloc.loop ?? true} muted={bloc.muted ?? true} playsinline></video>
        );
        if (bloc.type === 'gif') return (
          <img class="bloc-gif" src={bloc.src} alt={bloc.alt ?? ''} loading="lazy" />
        );
        if (bloc.type === 'galerie') return (
          <div class="bloc-galerie" style={`--cols: ${bloc.colonnes ?? 2}`}>
            {bloc.images.map((img: { src: string; alt?: string }) => (
              <img src={img.src} alt={img.alt ?? ''} loading="lazy" />
            ))}
          </div>
        );
        if (bloc.type === 'galerie-mixte') return (
          <div class="bloc-galerie">
            {bloc.items.map((item: { type: string; src: string; alt?: string }) => (
              item.type === 'video'
                ? <video src={item.src} autoplay loop muted playsinline class="bloc-galerie-media" />
                : <img src={item.src} alt={item.alt ?? ''} loading="lazy" class="bloc-galerie-media" />
            ))}
          </div>
        );
      })}
    </div>

  </article>

</Layout>

<style>
  /* SINGLE LAYOUT */
  .single {
    display: flex;
    align-items: flex-start;
    gap: calc(40 * var(--unit));
    padding: calc(64 * var(--unit)) calc(80 * var(--unit));
  }

  /* SIDEBAR */
  .sidebar { position: sticky; top: calc(24 * var(--unit)); width: calc(424 * var(--unit)); flex-shrink: 0; align-self: flex-start; }
  .sidebar-inner { display: flex; flex-direction: column; gap: calc(16 * var(--unit)); }
  .sidebar-back { display: inline-flex; align-items: center; gap: calc(16 * var(--unit)); font-size: var(--t-base); color: var(--dark); transition: opacity 0.2s; }
  .sidebar-back:hover { opacity: 0.6; }
  .sidebar-main { display: flex; flex-direction: column; gap: calc(86 * var(--unit)); }
  .sidebar-header { display: flex; flex-direction: column; gap: calc(24 * var(--unit)); }
  .sidebar-title { font-size: clamp(24px, calc(40 * var(--unit)), 40px); font-weight: 400; line-height: 1.1; color: var(--dark); }
  .sidebar-tags { display: flex; flex-wrap: wrap; gap: var(--s-2); }
  .sidebar-desc { font-size: var(--t-base); line-height: 1.5; color: var(--muted); }
  .sidebar-meta { display: flex; flex-direction: column; gap: calc(20 * var(--unit)); }
  .meta-item { display: flex; flex-direction: column; gap: calc(12 * var(--unit)); }
  .meta-item-row { display: flex; align-items: center; justify-content: space-between; width: 100%; }
  .meta-label { font-size: var(--t-base); font-weight: 400; color: var(--dark); text-transform: uppercase; letter-spacing: 0.02em; }
  .meta-value { font-size: var(--t-base); color: var(--muted); text-transform: uppercase; text-align: right; }
  .meta-link { cursor: pointer; transition: opacity 0.2s; }
  .meta-link:hover { opacity: 0.6; }
  .meta-sep { width: 100%; height: 1px; background: var(--border-cream); }

  /* CONTENT */
  .content { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: calc(40 * var(--unit)); }
  .bloc-text { font-size: clamp(16px, calc(20 * var(--unit)), 20px); font-weight: 400; line-height: 1.5; color: var(--dark); }
  .bloc-text--muted { color: var(--muted); }
  .bloc-image { display: flex; flex-direction: column; gap: var(--s-3); }
  .bloc-image img, .bloc-gif { width: 100%; height: calc(640 * var(--unit)); object-fit: cover; object-position: center; border-radius: var(--r-sm); background: var(--cream); }
  .bloc-image figcaption { font-size: var(--t-xs); color: var(--muted); }
  .bloc-video { width: 100%; height: auto; border-radius: var(--r-sm); background: var(--cream); display: block; }
  .bloc-galerie { display: grid; grid-template-columns: repeat(var(--cols, 2), 1fr); gap: calc(20 * var(--unit)); }
  .bloc-galerie img { width: 100%; height: calc(525 * var(--unit)); object-fit: cover; object-position: center; border-radius: var(--r-sm); background: var(--cream); }
  .bloc-galerie video,
  .bloc-galerie-media {
    width: 100%;
    height: calc(525 * var(--unit));
    object-fit: cover;
    object-position: center;
    border-radius: var(--r-sm);
    background: var(--cream);
  }

  /* MOBILE */
  @media (max-width: 768px) {
    .single { flex-direction: column; padding: 32px 20px; gap: 48px; }
    .sidebar { position: static; width: 100%; }
    .sidebar-main { gap: 40px; }
    .sidebar-title { font-size: clamp(24px, 8vw, 36px); }
    .content { width: 100%; gap: 32px; }
    .bloc-image img, .bloc-gif { height: auto; }
    .bloc-galerie { grid-template-columns: 1fr; }
    .bloc-galerie img { height: auto; }
    .bloc-galerie video,
    .bloc-galerie-media {
  height: auto;
}
  }
</style>
