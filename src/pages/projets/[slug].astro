---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SingleStatsRow from '../../components/SingleStatsRow.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projets');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { data } = project;
---

<Layout title={`${data.title} — Loïck Legallais`} description={data.description}>
  <article class="single">
    <div class="single__layout">
      <!-- LEFT — sticky sidebar -->
      <aside class="single__sidebar">
        <div class="single__sidebar-inner">
          <!-- Back link -->
          <a href="/projets" class="single__back">
            <svg width="16" height="8" viewBox="0 0 16 8" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M4 0L0 4M0 4L4 8M0 4H16" stroke="currentColor" stroke-width="1.5"/>
            </svg>
            <span>Retour aux projets</span>
          </a>

          <!-- Title block + tags -->
          <div class="single__intro">
            <div class="single__heading">
              <h1 class="single__title display">{data.title}</h1>
              {data.description && (
                <p class="single__description">{data.description}</p>
              )}
            </div>

            {data.fields && data.fields.length > 0 && (
              <ul class="single__tags">
                {data.fields.map((f) => <li class="tag">{f}</li>)}
              </ul>
            )}
          </div>

          <!-- Meta items (Année / Secteurs / etc.) -->
          {data.metaItems && data.metaItems.length > 0 && (
            <ul class="meta-list">
              {data.metaItems.map((item) => (
                <li class="meta-item">
                  <div class="meta-item__row">
                    <span class="meta-item__label">{item.label}</span>
                    <span class="meta-item__value">{item.value}</span>
                  </div>
                  <div class="meta-item__separator"></div>
                </li>
              ))}
            </ul>
          )}

          <!-- External link button -->
          {data.liveUrl && (
            <a href={data.liveUrl} target="_blank" rel="noopener noreferrer" class="single__cta">
              <span>Voir le site</span>
              <span class="single__cta-arrow" aria-hidden="true">
                <svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M18 0C26.3372 0 30.5059 0.000457093 33.1543 2.51758C33.2664 2.62416 33.3758 2.73357 33.4824 2.8457C35.9995 5.49411 36 9.66282 36 18C36 26.3372 35.9995 30.5059 33.4824 33.1543C33.3758 33.2664 33.2664 33.3758 33.1543 33.4824C30.5059 35.9995 26.3372 36 18 36C9.66282 36 5.49411 35.9995 2.8457 33.4824C2.73357 33.3758 2.62416 33.2664 2.51758 33.1543C0.000457093 30.5059 0 26.3372 0 18C0 9.66282 0.000457059 5.49411 2.51758 2.8457C2.62416 2.73357 2.73357 2.62416 2.8457 2.51758C5.49411 0.000457059 9.66282 0 18 0Z" fill="white"/>
<path d="M10 17.5C9.72386 17.5 9.5 17.7239 9.5 18C9.5 18.2761 9.72386 18.5 10 18.5V18V17.5ZM26.3536 18.3536C26.5488 18.1583 26.5488 17.8417 26.3536 17.6464L23.1716 14.4645C22.9763 14.2692 22.6597 14.2692 22.4645 14.4645C22.2692 14.6597 22.2692 14.9763 22.4645 15.1716L25.2929 18L22.4645 20.8284C22.2692 21.0237 22.2692 21.3403 22.4645 21.5355C22.6597 21.7308 22.9763 21.7308 23.1716 21.5355L26.3536 18.3536ZM10 18V18.5H26V18V17.5H10V18Z" fill="#31243D"/>
</svg>
              </span>
            </a>
          )}
        </div>
      </aside>

      <!-- RIGHT — scrolling content -->
      <div class="single__content">
        {data.blocs.map((bloc) => {
          if (bloc.type === 'text') {
            return <p class="bloc bloc--text">{bloc.contenu}</p>;
          }
          if (bloc.type === 'image') {
            return (
              <figure class="bloc bloc--image">
                <img src={bloc.src} alt={bloc.alt ?? ''} loading="lazy" />
                {bloc.legende && <figcaption>{bloc.legende}</figcaption>}
              </figure>
            );
          }
          if (bloc.type === 'video') {
            return (
              <video
                class="bloc bloc--video"
                src={bloc.src}
                poster={bloc.poster}
                autoplay={bloc.autoplay}
                loop={bloc.loop}
                muted={bloc.muted}
                playsinline
              ></video>
            );
          }
          if (bloc.type === 'gif') {
            return (
              <img
                class="bloc bloc--gif"
                src={bloc.src}
                alt={bloc.alt ?? ''}
                loading="lazy"
              />
            );
          }
          if (bloc.type === 'galerie') {
            return (
              <div
                class="bloc bloc--galerie"
                style={`--cols: ${bloc.colonnes}`}
              >
                {bloc.images.map((img) => (
                  <img src={img.src} alt={img.alt ?? ''} loading="lazy" />
                ))}
              </div>
            );
          }
        })}

        <!-- Stats row at the bottom (toggleable per project) -->
        {data.showStats && (
          <div class="bloc bloc--stats">
            <SingleStatsRow />
          </div>
        )}
      </div>
    </div>
  </article>
</Layout>

<style>
  /* ============================================
     LAYOUT — Figma: padding 120px 60px, gap auto via space-between
     ============================================ */
  .single {
    background: var(--color-white);
    padding: calc(80 * var(--unit)) var(--container-padding);
    /* Push below the floating menu (menu top + height ≈ 137 + 48 + breathing) */
    padding-top: calc(200 * var(--unit));
  }

  .single__layout {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: calc(60 * var(--unit));
  }

  /* ============================================
     SIDEBAR — sticky on desktop
     Figma: width 437px
     ============================================ */
  .single__sidebar {
    position: sticky;
    /* Stick below the floating menu */
    top: calc(140 * var(--unit));
    align-self: flex-start;
    width: calc(437 * var(--unit));
    flex: 0 0 auto;
  }

  .single__sidebar-inner {
    /* Figma: gap 16px between back link and the rest;
       then 86px between intro and meta. We replicate that visually. */
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* Back link */
  .single__back {
    display: inline-flex;
    align-items: center;
    gap: var(--space-4);
    color: var(--color-aubergine);
    font-size: var(--text-sm);
    transition: opacity var(--transition-base);
  }

  .single__back:hover {
    opacity: 0.7;
  }

  .single__back svg {
    flex-shrink: 0;
  }

  /* Big gap between intro block and the rest */
  .single__intro {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    margin-top: calc(40 * var(--unit) - var(--space-4));
  }

  .single__heading {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .single__title {
    /* Fluid: 28px mobile → 40px desktop (Figma single) */
    font-size: var(--text-title-single);
    color: var(--color-aubergine);
    margin: 0;
  }

  .single__description {
    /* Fluid: 16px mobile → 20px desktop */
    font-size: var(--text-desc-single);
    line-height: 1.4;
    color: var(--color-aubergine);
    margin: 0;
  }

  .single__tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .single__tags .tag {
    color: var(--color-aubergine);
  }

  /* Meta items list */
  .meta-list {
    list-style: none;
    margin: var(--space-5) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .meta-item__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    gap: var(--space-4);
  }

  .meta-item__label {
    font-size: var(--text-sm);
    color: #000;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .meta-item__value {
    font-size: var(--text-sm);
    color: #000;
    text-align: right;
    text-transform: uppercase;
  }

  .meta-item__separator {
    width: 100%;
    height: 1px;
    background: var(--color-aubergine);
    opacity: 0.3;
  }

  /* CTA "Voir le site" — same style as home CTA but dark on white sidebar */
  .single__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    background: var(--color-aubergine);
    color: var(--color-white);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    font-weight: 400;
    align-self: flex-start;
    margin-top: var(--space-5);
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .single__cta:hover {
    box-shadow: 0 12px 32px rgba(49, 36, 61, 0.2);
  }

  .single__cta-arrow {
    display: flex;
    width: calc(36 * var(--unit));
    height: calc(36 * var(--unit));
    min-width: 28px;
    min-height: 28px;
    transition: transform var(--transition-base);
  }

  /* ============================================
     RIGHT COLUMN — content (915px in Figma)
     ============================================ */
  .single__content {
    flex: 1 1 0;
    min-width: 0; /* avoid grid blowout */
    display: flex;
    flex-direction: column;
    gap: calc(60 * var(--unit));
    width: calc(915 * var(--unit));
    max-width: 100%;
  }

  /* Text — Figma: 22px medium desktop, color #232224. Fluid 16→22. */
  .bloc--text {
    font-size: var(--text-body-single);
    line-height: 1.4;
    font-weight: 500;
    color: var(--color-text-dark);
    margin: 0;
  }

  /* Image / GIF — Figma reference: 542px tall */
  .bloc--image {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .bloc--image img,
  .bloc--gif {
    width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    display: block;
    background: var(--color-placeholder);
  }

  .bloc--image figcaption {
    font-size: var(--text-xs);
    color: var(--color-aubergine);
    opacity: 0.6;
  }

  .bloc--video {
    width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    display: block;
    background: var(--color-placeholder);
  }

  /* Gallery — Figma: 2 cols, gap 20px, height 525px */
  .bloc--galerie {
    display: grid;
    grid-template-columns: repeat(var(--cols, 2), 1fr);
    gap: var(--space-5);
  }

  .bloc--galerie img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-md);
    background: var(--color-placeholder);
    /* Keep similar visual height per item */
    aspect-ratio: 1 / 1;
  }

  /* Stats at the bottom */
  .bloc--stats {
    margin-top: var(--space-5);
  }

  /* ============================================
     MOBILE — Figma: padding 60px 20px, sidebar on top
     ============================================ */
  @media (max-width: 768px) {
    .single {
      padding: 60px var(--container-padding);
      padding-top: 130px;
    }

    .single__layout {
      flex-direction: column;
      gap: 64px;
    }

    .single__sidebar {
      position: static;
      width: 100%;
    }

    .single__sidebar-inner {
      gap: 16px;
    }

    .single__intro {
      gap: 40px;
      margin-top: 0;
    }

    .single__heading {
      gap: 24px;
    }

    .meta-list {
      margin-top: 32px;
      gap: 20px;
    }

    .single__cta {
      padding: 12px 16px;
      gap: 12px;
      border-radius: 16px;
      margin-top: 32px;
    }

    .single__cta-arrow {
      width: 36px;
      height: 36px;
    }

    .single__content {
      width: 100%;
      gap: 60px;
    }

    /* Gallery: stack vertically on mobile (Figma) */
    .bloc--galerie {
      grid-template-columns: 1fr !important;
    }

    .bloc--galerie img {
      aspect-ratio: 451 / 300;
    }
  }
</style>
