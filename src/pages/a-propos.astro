---

<Layout title="À propos — Loïck Legallais" description="Designer UI/UX freelance basé à Lyon. Découvrez mon parcours et ma vision du design.">

  <!-- HERO — titre + sous-titre + chiffres clés en ligne -->
  <section class="hero-wrap">
    <div class="hero">
      <div class="hero-content">
        <h1 class="hero-title">A propos</h1>
        <p class="hero-subtitle">
          Designer UI/UX freelance basé à Lyon, je crée des interfaces pensées pour vos objectifs depuis plus de 7 ans.
        </p>
      </div>

      <!-- Chiffres clés (4 colonnes) -->
      <div class="hero-stats">
        {stats.map((stat) => (
          <div class="hero-stat">
            <span class="hero-stat-value">{stat.value}</span>
            <span class="hero-stat-label">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- MÉTHODOLOGIE — identique à la home -->
  <section class="methodo-wrap">
    <div class="methodo">
      <h2 class="section-title">Une méthodologie efficace et sur mesure.</h2>
      <div class="methodo-grid">
        {methodo.map((step) => (
          <div class="methodo-card">
            <span class="methodo-card-title">{step.title}</span>
            <div class="methodo-card-icon" set:html={step.icon}></div>
            <p class="methodo-card-text">{step.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DAMIER — texte gauche + photo droite -->
  <section class="damier">
    <div class="damier-text">
      <h2 class="damier-title">Passionné depuis toujours</h2>
      <p class="damier-desc">
        Aliquam viverra tempor id pellentesque cras phasellus lacus. Euismod fringilla suscipit purus ut non. Phasellus pellentesque odio morbi lacus. Malesuada enim commodo tempus in suscipit sit. Venenatis sapien ultricies leo amet turpis at tempor.
      </p>
    </div>
    <div class="damier-image">
           <img src="/images/photo-loick-legallais.jpg" alt="Loïck Legallais" class="damier-image-media" /> -->
      <div class="damier-image-placeholder"></div>
    </div>
  </section>

</Layout>

<style>
  /* HERO */
  .hero-wrap { padding: 0 var(--outer-pad); }
  .hero {
    background: var(--white);
    border-radius: 0 0 var(--r-lg) var(--r-lg);
    padding: calc(100 * var(--unit)) var(--inner-pad-x) calc(64 * var(--unit));
    display: flex;
    flex-direction: column;
    gap: calc(80 * var(--unit));
  }
  .hero-content {
    display: flex;
    flex-direction: column;
    gap: calc(16 * var(--unit));
    max-width: calc(887 * var(--unit));
    width: 100%;
  }
  .hero-title {
    font-size: var(--t-hero);
    font-weight: 400;
    line-height: 1.1;
    color: var(--dark);
    letter-spacing: -0.01em;
  }
  .hero-subtitle {
    font-size: clamp(15px, calc(20 * var(--unit)), 20px);
    line-height: 1.5;
    color: var(--muted);
    max-width: calc(655 * var(--unit));
  }

  /* Chiffres clés en ligne */
  .hero-stats {
    display: flex;
    gap: calc(40 * var(--unit));
    width: 100%;
  }
  .hero-stat {
    flex: 1 0 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: calc(24 * var(--unit));
  }
  .hero-stat-value {
    font-size: var(--t-hero);
    font-weight: 400;
    line-height: 1.1;
    color: var(--dark);
  }
  .hero-stat-label {
    font-size: clamp(14px, calc(18 * var(--unit)), 18px);
    line-height: 1.3;
    color: rgba(49, 36, 61, 0.7);
  }

  /* MÉTHODOLOGIE */
  .methodo-wrap { padding: calc(28 * var(--unit)) var(--outer-pad); }
  .methodo { background: var(--cream); border-radius: var(--r-lg); padding: var(--inner-pad-y) var(--inner-pad-x); display: flex; flex-direction: column; gap: var(--s-16); }
  .methodo-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--s-10); }
  .methodo-card { background: var(--white); border-radius: var(--r-sm); padding: calc(28 * var(--unit)); height: calc(428 * var(--unit)); min-height: 200px; display: flex; flex-direction: column; justify-content: space-between; align-items: center; transition: transform 0.3s var(--ease); }
  .methodo-card:hover { transform: translateY(-4px); }
  .methodo-card-title { font-size: var(--t-lg); font-weight: 500; color: var(--purple); line-height: 1.5; width: 100%; }
  .methodo-card-icon { display: flex; align-items: center; justify-content: center; flex: 1; }
  .methodo-card-icon svg { max-width: 100%; height: auto; }
  .methodo-card-text { font-size: clamp(14px, calc(20 * var(--unit)), 20px); color: var(--muted); line-height: 1.5; width: 100%; }

  /* DAMIER */
  .damier {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: calc(40 * var(--unit));
    padding: var(--inner-pad-y) var(--inner-pad-x);
  }
  .damier-text {
    display: flex;
    flex-direction: column;
    gap: calc(60 * var(--unit));
    flex: 0 0 calc(658 * var(--unit));
    max-width: calc(658 * var(--unit));
  }
  .damier-title {
    font-size: var(--t-xl);
    font-weight: 400;
    line-height: 1.1;
    color: var(--dark);
  }
  .damier-desc {
    font-size: clamp(16px, calc(20 * var(--unit)), 20px);
    line-height: 1.5;
    color: var(--muted);
    max-width: calc(568 * var(--unit));
  }
  .damier-image {
    flex: 0 0 calc(655 * var(--unit));
    max-width: calc(655 * var(--unit));
    height: calc(649 * var(--unit));
    min-height: 300px;
    border-radius: var(--r-sm);
    overflow: hidden;
    position: relative;
  }
  .damier-image-placeholder { width: 100%; height: 100%; background: var(--cream); }
  .damier-image-media { width: 100%; height: 100%; object-fit: cover; object-position: bottom; }

  /* MOBILE */
  @media (max-width: 768px) {
    .hero-wrap { padding: 0 12px; }
    .hero { padding: 40px 24px; gap: 48px; }
    .hero-title { font-size: clamp(28px, 8vw, 48px); }
    .hero-subtitle { font-size: 16px; }
    .hero-stats { flex-wrap: wrap; gap: 32px; }
    .hero-stat { flex: 1 0 40%; }
    .hero-stat-value { font-size: clamp(36px, 10vw, 56px); }

    .methodo-wrap { padding: 20px 12px; }
    .methodo { padding: 40px 24px; }
    .methodo-grid { grid-template-columns: 1fr; gap: 16px; }
    .methodo-card { height: auto; min-height: 160px; padding: 24px; gap: 24px; }

    .damier { flex-direction: column; padding: 40px 20px; gap: 40px; }
    .damier-text { flex: none; width: 100%; max-width: 100%; gap: 32px; }
    .damier-image { flex: none; width: 100%; max-width: 100%; height: 520px; }
    .damier-desc { flex: none; max-width: 100%; }
  }
</style>
