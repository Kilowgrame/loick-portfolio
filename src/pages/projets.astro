---
import Layout from '../layouts/LayoutV2.astro';
import { getCollection } from 'astro:content';

const allProjets = (await getCollection('projets'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => a.data.order - b.data.order);

// Principaux = order 1-6
const principaux = allProjets.filter((p) => p.data.order <= 6);
const projetsRow1 = principaux.slice(0, 3);
const projetsRow2 = principaux.slice(3, 6);

// Secondaires = order 7+
const projetsSecondaires = allProjets.filter((p) => p.data.order > 6);
---

<Layout title="Projets — Loïck Legallais" description="Découvrez les derniers projets de Loïck Legallais, designer UI/UX freelance.">

  <!-- HERO -->
  <section class="hero-wrap">
    <div class="hero">
      <div class="hero-content">
        <h1 class="hero-title">Découvrez les derniers projets</h1>
        <p class="hero-subtitle">Branding, UI / UX Design, Product Design... Découvrez les derniers projets marquants...</p>
      </div>
    </div>
  </section>

  <!-- PROJETS -->
  <section class="projets">
    <div class="projets-row">
      {projetsRow1.map((p) => (
        <a href={`/projets/${p.slug}`} class={`projet-card ${p.data.wide ? 'projet-card--wide' : ''}`}>
          <div class="projet-card-img" style={`background-color: ${p.data.bgColor}`}>
            {p.data.cardImage && <img src={p.data.cardImage} alt={p.data.title} class="projet-card-media" />}
          </div>
          <div class="projet-card-content">
            <div class="projet-card-text">
              <span class="projet-card-title">{p.data.title}</span>
              <span class="projet-card-desc">{p.data.cardDescription ?? p.data.description}</span>
            </div>
            <div class="projet-card-tags">{p.data.fields.map((t) => <span class="tag">{t}</span>)}</div>
          </div>
        </a>
      ))}
    </div>

    <div class="projets-row">
      {projetsRow2.map((p) => (
        <a href={`/projets/${p.slug}`} class={`projet-card ${p.data.wide ? 'projet-card--wide' : ''}`}>
          <div class="projet-card-img" style={`background-color: ${p.data.bgColor}`}>
            {p.data.cardImage && <img src={p.data.cardImage} alt={p.data.title} class="projet-card-media" />}
          </div>
          <div class="projet-card-content">
            <div class="projet-card-text">
              <span class="projet-card-title">{p.data.title}</span>
              <span class="projet-card-desc">{p.data.cardDescription ?? p.data.description}</span>
            </div>
            <div class="projet-card-tags">{p.data.fields.map((t) => <span class="tag">{t}</span>)}</div>
          </div>
        </a>
      ))}
    </div>

    {projetsSecondaires.length > 0 && <div class="projets-separator" aria-hidden="true"></div>}

    {projetsSecondaires.length > 0 && (
      <div class="projets-row projets-row--secondaires">
        {projetsSecondaires.map((p) => (
          <a href={`/projets/${p.slug}`} class="projet-card projet-card--secondaire">
            <div class="projet-card-img" style={`background-color: ${p.data.bgColor}`}>
              {p.data.cardImage && <img src={p.data.cardImage} alt={p.data.title} class="projet-card-media" />}
            </div>
            <div class="projet-card-content">
              <div class="projet-card-text">
                <span class="projet-card-title">{p.data.title}</span>
                <span class="projet-card-desc">{p.data.cardDescription ?? p.data.description}</span>
              </div>
              <div class="projet-card-tags">{p.data.fields.map((t) => <span class="tag">{t}</span>)}</div>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>

</Layout>

<style>
  /* HERO */
  .hero-wrap { padding: 0 var(--outer-pad); }
  .hero {
    background: var(--white);
    height: calc(441 * var(--unit));
    min-height: 240px;
    padding: calc(100 * var(--unit)) var(--inner-pad-x) calc(64 * var(--unit));
    display: flex;
    align-items: flex-end;
  }
  .hero-content { display: flex; flex-direction: column; gap: calc(16 * var(--unit)); max-width: calc(887 * var(--unit)); width: 100%; }
  .hero-title { font-size: var(--t-hero); font-weight: 400; line-height: 1.1; color: var(--dark); letter-spacing: -0.01em; }
  .hero-subtitle { font-size: clamp(15px, calc(20 * var(--unit)), 20px); line-height: 1.5; color: var(--muted); max-width: calc(655 * var(--unit)); }

  /* PROJETS */
  .projets { padding: var(--inner-pad-y) var(--inner-pad-x); display: flex; flex-direction: column; gap: var(--s-10); }
  .projets-row { display: flex; align-items: flex-start; gap: var(--s-10); width: 100%; }
  .projets-separator { height: 1px; background: var(--border-cream); width: 100%; margin: calc(24 * var(--unit)) 0; }
  .projet-card { flex: 1 1 0; min-width: 0; display: flex; flex-direction: column; gap: var(--s-5); cursor: pointer; text-decoration: none; }
  .projet-card--wide { flex: 0 0 calc(655 * var(--unit)); min-width: 0; max-width: calc(655 * var(--unit)); }
  .projets-row--secondaires { flex-wrap: wrap; }
  .projet-card--secondaire { flex: 1 0 calc(30%); max-width: calc((100% - 2 * var(--s-10)) / 3); }
  .projet-card-img { position: relative; width: 100%; border-radius: var(--r-sm); aspect-ratio: 6 / 5;; overflow: hidden; transition: transform 0.4s var(--ease); }
  .projet-card:hover .projet-card-img { transform: scale(1.02); }
  .projet-card--wide .projet-card-img { aspect-ratio: 424/300; }
  .projet-card--secondaire .projet-card-img { aspect-ratio: 16/11; height: auto; }
  .projet-card-media { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center; }
  .projet-card-content { display: flex; flex-direction: column; gap: var(--s-6); }
  .projet-card-text { display: flex; flex-direction: column; gap: var(--s-2); }
  .projet-card-title { font-size: var(--t-lg); font-weight: 400; color: var(--dark); line-height: 1.3; transition: color 0.2s; }
  .projet-card:hover .projet-card-title { color: var(--teal); }
  .projet-card-desc { font-size: var(--t-base); color: var(--muted); line-height: 1.5; }
  .projet-card-tags { display: flex; flex-wrap: wrap; gap: var(--s-5); align-items: flex-start; }

  /* MOBILE */
  @media (max-width: 768px) {
    .hero-wrap { padding: 0 12px; }
    .hero { height: auto; min-height: 200px; padding: 40px 24px 40px; align-items: flex-start; border: none; }
    .hero-title { font-size: clamp(28px, 8vw, 48px); }
    .hero-subtitle { font-size: 16px; max-width: 100%;}
    .hero-content { max-width: 100%; }
    .projets { padding: 40px 20px; gap: 40px; }
    .projets-row { flex-direction: column; gap: 32px; }
    .projet-card, .projet-card--wide, .projet-card--secondaire { flex: none; width: 100%; max-width: 100%; }
    .projet-card-text { gap: 8px; }
    .projet-card { gap: 20px; }
    .projet-card-content { gap: 24px; }
  }
</style>
