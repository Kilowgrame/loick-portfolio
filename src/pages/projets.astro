---
import Layout from '../layouts/LayoutV2.astro';

const projetsRow1 = [
  { title: 'LikeWatt', description: 'Refonte technique et design du site de SBG Systems, pionnier des systèmes de navigation pour véhicules autonome.', tags: ['UI / UX Design', 'Product Design'], slug: 'likewatt', bgColor: '#d9d9d9', wide: true, media: null },
  { title: 'SBG Systems', description: 'Refonte technique et design du site de SBG Systems, pionnier des systèmes de navigation pour véhicules autonome.', tags: ['UI / UX Design'], slug: 'sbg-systems', bgColor: '#03223f', wide: false, media: null },
  { title: 'Wikit', description: 'Refonte technique et design du site de SBG Systems, pionnier des systèmes de navigation pour véhicules autonome.', tags: ['UI / UX Design'], slug: 'wikit', bgColor: '#e1ecfd', wide: false, media: null },
];

const projetsRow2 = [
  { title: 'Manerty', description: 'Refonte technique et design du site de SBG Systems, pionnier des systèmes de navigation pour véhicules autonome.', tags: ['UI / UX Design', 'Product Design'], slug: 'manerty', bgColor: '#3662e3', wide: false, media: null },
  { title: 'Los Primos', description: 'Refonte technique et design du site de SBG Systems, pionnier des systèmes de navigation pour véhicules autonome.', tags: ['UI / UX Design'], slug: 'los-primos', bgColor: '#d9d9d9', wide: true, media: null },
  { title: 'Le Spot', description: 'Refonte technique et design du site de SBG Systems, pionnier des systèmes de navigation pour véhicules autonome.', tags: ['UI / UX Design', 'Branding'], slug: 'le-spot', bgColor: '#4b3c32', wide: false, media: null },
];

const projetsSecondaires = [
  { title: 'Sport dans la ville', description: 'Refonte technique et design du site de SBG Systems, pionnier des systèmes de navigation pour véhicules autonome.', tags: ['UI / UX Design'], slug: 'sport-dans-la-ville', bgColor: '#03223f', media: null },
  { title: 'Homnium', description: 'Refonte technique et design du site de SBG Systems, pionnier des systèmes de navigation pour véhicules autonome.', tags: ['UI / UX Design'], slug: 'homnium', bgColor: '#03223f', media: null },
  { title: 'Olivier Marcotte', description: 'Refonte technique et design du site de SBG Systems, pionnier des systèmes de navigation pour véhicules autonome.', tags: ['UI / UX Design'], slug: 'olivier-marcotte', bgColor: '#e1ecfd', media: null },
];
---

<Layout title="Projets — Loïck Legallais" description="Découvrez les derniers projets de Loïck Legallais, designer UI/UX freelance.">

  <!-- HERO -->
  <section class="hero-wrap">
    <div class="hero">
      <div class="hero-content">
        <h1 class="hero-title">Découvrez les derniers projets</h1>
        <p class="hero-subtitle">Branding, UI / UX Design, Product Design... Découvrez les derniers projets marquants...</p>
      </div>
    </div>
  </section>

  <!-- PROJETS -->
  <section class="projets">
    <div class="projets-row">
      {projetsRow1.map((p) => (
        <a href={`/projets/${p.slug}`} class={`projet-card ${p.wide ? 'projet-card--wide' : ''}`}>
          <div class="projet-card-img" style={`background-color: ${p.bgColor}`}>
            {p.media?.type === 'image' && <img src={p.media.src} alt={p.title} class="projet-card-media" />}
            {p.media?.type === 'video' && <video src={p.media.src} class="projet-card-media" autoplay loop muted playsinline />}
          </div>
          <div class="projet-card-content">
            <div class="projet-card-text">
              <span class="projet-card-title">{p.title}</span>
              <span class="projet-card-desc">{p.description}</span>
            </div>
            <div class="projet-card-tags">{p.tags.map((t) => <span class="tag">{t}</span>)}</div>
          </div>
        </a>
      ))}
    </div>

    <div class="projets-row">
      {projetsRow2.map((p) => (
        <a href={`/projets/${p.slug}`} class={`projet-card ${p.wide ? 'projet-card--wide' : ''}`}>
          <div class="projet-card-img" style={`background-color: ${p.bgColor}`}>
            {p.media?.type === 'image' && <img src={p.media.src} alt={p.title} class="projet-card-media" />}
            {p.media?.type === 'video' && <video src={p.media.src} class="projet-card-media" autoplay loop muted playsinline />}
          </div>
          <div class="projet-card-content">
            <div class="projet-card-text">
              <span class="projet-card-title">{p.title}</span>
              <span class="projet-card-desc">{p.description}</span>
            </div>
            <div class="projet-card-tags">{p.tags.map((t) => <span class="tag">{t}</span>)}</div>
          </div>
        </a>
      ))}
    </div>

    {projetsSecondaires.length > 0 && <div class="projets-separator" aria-hidden="true"></div>}

    {projetsSecondaires.length > 0 && (
      <div class="projets-row projets-row--secondaires">
        {projetsSecondaires.map((p) => (
          <a href={`/projets/${p.slug}`} class="projet-card projet-card--secondaire">
            <div class="projet-card-img" style={`background-color: ${p.bgColor}`}>
              {p.media?.type === 'image' && <img src={p.media.src} alt={p.title} class="projet-card-media" />}
              {p.media?.type === 'video' && <video src={p.media.src} class="projet-card-media" autoplay loop muted playsinline />}
            </div>
            <div class="projet-card-content">
              <div class="projet-card-text">
                <span class="projet-card-title">{p.title}</span>
                <span class="projet-card-desc">{p.description}</span>
              </div>
              <div class="projet-card-tags">{p.tags.map((t) => <span class="tag">{t}</span>)}</div>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>

</Layout>

<style>
  /* HERO */
  .hero-wrap { padding: 0 var(--outer-pad); }
  .hero {
    background: var(--white);
    border: 1px solid var(--border-cream);
    border-top: none;
    border-radius: 0 0 var(--r-lg) var(--r-lg);
    height: calc(441 * var(--unit));
    min-height: 240px;
    padding: calc(100 * var(--unit)) var(--inner-pad-x) calc(64 * var(--unit));
    display: flex;
    align-items: flex-end;
  }
  .hero-content { display: flex; flex-direction: column; gap: calc(16 * var(--unit)); max-width: calc(887 * var(--unit)); width: 100%; }
  .hero-title { font-size: var(--t-hero); font-weight: 400; line-height: 1.1; color: var(--dark); letter-spacing: -0.01em; }
  .hero-subtitle { font-size: clamp(15px, calc(20 * var(--unit)), 20px); line-height: 1.5; color: var(--muted); max-width: calc(655 * var(--unit)); }

  /* PROJETS */
  .projets { padding: var(--inner-pad-y) var(--inner-pad-x); display: flex; flex-direction: column; gap: var(--s-10); }
  .projets-row { display: flex; align-items: flex-start; gap: var(--s-10); }
  .projets-separator { height: 1px; background: var(--border-cream); width: 100%; margin: calc(24 * var(--unit)) 0; }
  .projet-card { flex: 1 0 0; min-width: 0; display: flex; flex-direction: column; gap: var(--s-5); cursor: pointer; text-decoration: none; }
  .projet-card--wide { flex: 0 0 calc(655 * var(--unit)); max-width: calc(655 * var(--unit)); }
  .projets-row--secondaires { flex-wrap: wrap; }
  .projet-card--secondaire { flex: 1 0 calc(30%); max-width: calc((100% - 2 * var(--s-10)) / 3); }
  .projet-card-img { position: relative; width: 100%; border-radius: var(--r-sm); aspect-ratio: 16/11; overflow: hidden; transition: transform 0.4s var(--ease); }
  .projet-card:hover .projet-card-img { transform: scale(1.02); }
  .projet-card--wide .projet-card-img { aspect-ratio: 424/300; }
  .projet-card--secondaire .projet-card-img { aspect-ratio: 16/11; height: auto; }
  .projet-card-media { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center; }
  .projet-card-content { display: flex; flex-direction: column; gap: var(--s-6); }
  .projet-card-text { display: flex; flex-direction: column; gap: var(--s-2); }
  .projet-card-title { font-size: var(--t-lg); font-weight: 400; color: var(--dark); line-height: 1.3; transition: color 0.2s; }
  .projet-card:hover .projet-card-title { color: var(--teal); }
  .projet-card-desc { font-size: var(--t-base); color: var(--muted); line-height: 1.5; }
  .projet-card-tags { display: flex; flex-wrap: wrap; gap: var(--s-5); align-items: flex-start; }

  /* MOBILE */
  @media (max-width: 768px) {
    .hero-wrap { padding: 0 12px; }
    .hero { height: auto; min-height: 200px; padding: 40px 24px 40px; align-items: flex-start; border: none; }
    .hero-title { font-size: clamp(28px, 8vw, 48px); }
    .hero-subtitle { font-size: 16px; }
    .projets { padding: 40px 20px; gap: 40px; }
    .projets-row { flex-direction: column; gap: 32px; }
    .projet-card, .projet-card--wide, .projet-card--secondaire { flex: none; width: 100%; max-width: 100%; }
  }
</style>
