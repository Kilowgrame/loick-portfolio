---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

// Get all projects, filter out drafts, sort by 'order' field
const projects = (await getCollection('projets'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => a.data.order - b.data.order);

// Build the categories list dynamically from all projects + "Tout"
const categoriesSet = new Set(
  projects.map((p) => p.data.category).filter(Boolean) as string[]
);
const categories = ['Tout', ...Array.from(categoriesSet)];
---

<Layout title="Projets — Loïck Legallais">
  <!-- Green hero with "PROJETS" title -->
  <section class="projects-hero">
    <div class="projects-hero__inner">
      <h1 class="projects-hero__title display">PROJETS</h1>
    </div>
  </section>

  <!-- Main content: filters + cards grid -->
  <section class="projects-archive">
    <!-- Filter buttons -->
    <div class="filters">
      {categories.map((cat) => (
        <button
          class:list={['filter-btn', { 'is-active': cat === 'Tout' }]}
          data-filter={cat}
        >
          {cat}
        </button>
      ))}
    </div>

    <!-- Cards grid -->
    <div class="cards-grid">
      {projects.map((project) => (
        <a
          href={`/projets/${project.slug}`}
          class="project-card fade-in"
          data-category={project.data.category}
        >
          <div class="project-card__image">
            {project.data.cover ? (
              <img src={project.data.cover} alt={project.data.coverAlt ?? project.data.title} loading="lazy" />
            ) : (
              <div class="project-card__placeholder" style={`background: ${project.data.bgColor}`}></div>
            )}
          </div>
          {project.data.category && (
            <span class="tag project-card__tag">{project.data.category}</span>
          )}
          <h2 class="project-card__title">{project.data.title}</h2>
        </a>
      ))}
    </div>
  </section>
</Layout>

<script>
  // Filter cards by category when a filter button is clicked
  document.addEventListener('DOMContentLoaded', () => {
    const filterButtons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const cards = document.querySelectorAll<HTMLAnchorElement>('.project-card');

    filterButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;

        // Update active button visual state
        filterButtons.forEach((b) => b.classList.remove('is-active'));
        btn.classList.add('is-active');

        // Show / hide cards
        cards.forEach((card) => {
          const matches = filter === 'Tout' || card.dataset.category === filter;
          (card as HTMLElement).style.display = matches ? '' : 'none';
        });
      });
    });
  });
</script>

<style>
  /* ============================================
     HERO — green band with big title
     ============================================ */
  .projects-hero {
    background-color: var(--color-green);
    padding: calc(133 * var(--unit)) var(--container-padding) calc(40 * var(--unit));
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
  }

  .projects-hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: calc(1392 * var(--unit));
  }

  .projects-hero__title {
    /* Fluid: 48px mobile → 102px desktop */
    font-size: var(--text-archive-hero);
    color: var(--color-aubergine);
    text-align: center;
    letter-spacing: 0.02em;
    margin: 0;
    width: 100%;
  }

  /* ============================================
     ARCHIVE — filters + grid
     ============================================ */
  .projects-archive {
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
    padding: var(--space-30) var(--container-padding);
    background: var(--color-white);
  }

  /* Filters */
  .filters {
    display: flex;
    gap: calc(28 * var(--unit));
    align-items: center;
    flex-wrap: wrap;
  }

  .filter-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
    border: 1px solid var(--color-aubergine);
    border-radius: var(--radius-sm);
    background: var(--color-white);
    color: #000;
    /* Fluid: 14px mobile → 16px desktop */
    font-size: var(--text-filter);
    font-family: var(--font-body);
    cursor: pointer;
    transition: background var(--transition-base), color var(--transition-base);
  }

  .filter-btn:hover {
    background: var(--color-aubergine);
    color: var(--color-white);
  }

  .filter-btn.is-active {
    background: var(--color-aubergine);
    color: var(--color-white);
  }

  /* Cards grid — 2 cols desktop, 1 col mobile */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-16) var(--space-10);
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    text-decoration: none;
    color: var(--color-aubergine);
    transition: transform var(--transition-base);
  }

  .project-card:hover {
    transform: translateY(-4px);
  }

  .project-card__image {
    width: 100%;
    aspect-ratio: 451 / 300;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-placeholder);
  }

  .project-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out);
  }

  .project-card:hover .project-card__image img {
    transform: scale(1.04);
  }

  .project-card__placeholder {
    width: 100%;
    height: 100%;
  }

  .project-card__tag {
    color: var(--color-aubergine);
    align-self: flex-start;
  }

  .project-card__title {
    font-family: var(--font-body);
    /* Fluid: 18px mobile → 24px desktop */
    font-size: var(--text-card-title);
    font-weight: 500;
    line-height: 1.2;
    margin: 0;
  }

  /* ============================================
     MOBILE
     ============================================ */
  @media (max-width: 768px) {
    .projects-hero {
      padding: 133px var(--container-padding) 40px;
      min-height: 399px;
    }

    .projects-archive {
      gap: 64px;
      padding: 60px var(--container-padding);
    }

    .filters {
      gap: 28px;
    }

    .filter-btn {
      padding: 16px;
      border-radius: 16px;
    }

    .cards-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .project-card {
      gap: 20px;
    }

    .project-card__image {
      border-radius: 20px;
    }
  }
</style>
