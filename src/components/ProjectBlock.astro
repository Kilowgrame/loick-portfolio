---
// Reusable colored project block
interface Props {
  title: string;
  description: string;
  tags: string[];
  bgColor?: string;
  textColor?: string;
  image?: string;
  href?: string;
  imageAlt?: string;
}

const {
  title,
  description,
  tags,
  bgColor = '#06535e',
  textColor = '#ffffff',
  image,
  href = '#',
  imageAlt = ''
} = Astro.props;
---

<a
  href={href}
  class="project-block fade-in"
  style={`--block-bg: ${bgColor}; --block-color: ${textColor};`}
>
  <div class="project-block__text">
    <div class="project-block__heading">
      <h2 class="project-block__title display">{title}</h2>
      <p class="project-block__description">{description}</p>
    </div>

    <ul class="project-block__tags">
      {tags.map((tag) => (
        <li class="tag">{tag}</li>
      ))}
    </ul>
  </div>

  <div class="project-block__image">
    {image ? (
      <img src={image} alt={imageAlt} loading="lazy" />
    ) : (
      <div class="project-block__placeholder"></div>
    )}
  </div>
</a>

<style>
  /* DESKTOP — text and image side-by-side */
  .project-block {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-15);
    padding: var(--space-15) var(--container-padding) var(--space-30);
    background: var(--block-bg);
    color: var(--block-color);
    text-decoration: none;
    transition: filter var(--transition-base);
  }

  .project-block:hover {
    filter: brightness(1.05);
  }

  .project-block__text {
    flex: 1;
    max-width: calc(658 * var(--unit));
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
  }

  .project-block__heading {
    display: flex;
    flex-direction: column;
    gap: var(--space-15);
  }

  .project-block__title {
    font-size: var(--text-2xl);
    margin: 0;
    color: var(--block-color);
  }

  .project-block__description {
    font-size: var(--text-md);
    line-height: 1.4;
    color: var(--block-color);
    max-width: calc(568 * var(--unit));
  }

  .project-block__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .project-block__tags .tag {
    color: var(--block-color);
    border-color: var(--block-color);
  }

  .project-block__image {
    flex: 0 0 calc(560 * var(--unit));
    aspect-ratio: 560 / 338;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: rgba(255, 255, 255, 0.4);
    transition: transform 0.6s var(--ease-out);
  }

  .project-block:hover .project-block__image {
    transform: scale(1.02);
  }

  .project-block__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-block__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(255,255,255,0.3) 0%, rgba(255,255,255,0.1) 100%);
  }

  /* MOBILE — stacked vertically (text on top, image below) */
  @media (max-width: 768px) {
    .project-block {
      /* Figma: padding 60px X, gap 60px, column (X fluid) */
      flex-direction: column;
      gap: 60px;
      padding: 60px var(--container-padding);
    }

    .project-block__text {
      /* Figma: gap 28px between heading & tags */
      max-width: 100%;
      gap: 28px;
    }

    .project-block__heading {
      /* Figma: gap 40px between title & description */
      gap: 40px;
    }

    .project-block__title {
      /* Figma: 40px */
      font-size: 40px;
    }

    .project-block__description {
      /* Figma: 18px */
      font-size: 18px;
      max-width: 100%;
    }

    .project-block__image {
      /* Figma: full width with 560/338 ratio */
      flex: none;
      width: 100%;
      border-radius: 20px;
    }
  }
</style>
