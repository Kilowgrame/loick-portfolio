---
// Last resources section
interface Resource {
  title: string;
  category: string;
  href?: string;
  image?: string;
}

interface Props {          
  showTitle?: boolean;
}
const { showTitle = true } = Astro.props; 

const resources: Resource[] = [
  { title: 'WebP Manager', category: 'Plugin Figma', href: 'https://www.figma.com/community/plugin/1587802543036369275/webp-manager-rename-resize-export', image: '/images/ressources/plugin-figma.png'},
  { title: 'Template Application de discussion (Prochainement)', category: 'Fichier figma', href: '#', image: '/images/ressources/template-chat.png'},
  { title: 'Template Site e-commerce (Prochainement)', category: 'Fichier figma', href: '#', image: '/images/ressources/e-commerce.png'},
];
---

<section class="resources">
 {showTitle && (
  <h2 class="resources__heading display fade-in" style="word-spacing: 4px;">
    Quelques  ressources  à  disposition
  </h2>
)}

  <div class="resources__grid">
    {resources.map((resource) => (
      <a
        href={resource.href ?? '#'}
        target="_blank"
        rel="noopener noreferrer"
        class="resource-card fade-in"
      >
        <div class="resource-card__image">
          {resource.image && <img src={resource.image} alt="" loading="lazy" />}
        </div>
        <span class="tag resource-card__tag">{resource.category}</span>
        <p class="resource-card__title">{resource.title}</p>
      </a>
    ))}
  </div>
</section>

<style>
  /* DESKTOP */
  .resources {
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
    padding: var(--space-30) var(--container-padding);
    background: var(--color-white);
  }

  .resources__heading {
    font-size: var(--text-xl);
    color: var(--color-aubergine);
    margin: 0;
    max-width: calc(800 * var(--unit));
    line-height: 1.1;
  }

  .resources__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  .resource-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    text-decoration: none;
    color: var(--color-aubergine);
    transition: transform var(--transition-base);
  }

  .resource-card:hover {
    transform: translateY(-4px);
  }

  .resource-card__image {
    width: 100%;
    aspect-ratio: 451 / 300;
    background: var(--color-placeholder);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .resource-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .resource-card__tag {
    color: var(--color-aubergine);
    align-self: flex-start;
  }

  .resource-card__title {
    font-size: var(--text-md);
    font-weight: 500;
    line-height: 1.2;
  }

  /* MOBILE — Figma: gap 64px, padding 60px 20px, single col */
  @media (max-width: 768px) {
    .resources {
      gap: 64px;
      padding: 60px var(--container-padding);
    }

    .resources__heading {
      /* Figma: 28px */
      font-size: 28px;
      max-width: 100%;
    }

    .resources__grid {
      /* Figma: single column, gap 40px */
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .resource-card {
      /* Figma: gap 20px */
      gap: 20px;
    }

    .resource-card__image {
      border-radius: 20px;
    }

    .resource-card__title {
      /* Figma: 24px */
      font-size: 24px;
    }
  }
</style>
