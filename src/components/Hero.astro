---
// Hero — simple text-centered hero with 5 floating stickers around.
// No image, no frame. Text "LOICK LEGALLAIS" big and centered, with
// "UI / UX Designer · Freelance" subtitle below.
import Parallax from './Parallax.astro';
---

<section class="hero" data-parallax-container>
  <div class="hero__inner">
    <!-- The 5 stickers, positioned absolutely around the text -->

    <img
      src="/images/stickers/etoile.svg"
      alt=""
      class="sticker sticker--etoile"
      data-parallax="-0.40"
      data-rotation="19.32"
      aria-hidden="true"
    />

    <img
      src="/images/stickers/eyes.svg"
      alt=""
      class="sticker sticker--eyes"
      data-parallax="-0.55"
      data-rotation="-6.11"
      aria-hidden="true"
    />

    <img
      src="/images/stickers/galaxy.svg"
      alt=""
      class="sticker sticker--galaxy"
      data-parallax="-0.45"
      data-rotation="0"
      aria-hidden="true"
    />

    <img
      src="/images/stickers/peace.svg"
      alt=""
      class="sticker sticker--peace"
      data-parallax="-0.30"
      data-rotation="24.81"
      aria-hidden="true"
    />

    <img
      src="/images/stickers/planete.svg"
      alt=""
      class="sticker sticker--planete"
      data-parallax="-0.35"
      data-rotation="-6.28"
      aria-hidden="true"
    />

    <!-- Centered text -->
    <div class="hero__title">
      <span class="hero__name display">LOICK</span>
      <span class="hero__name display">LEGALLAIS</span>
    </div>

    <div class="hero__meta">
      <span>UI / UX Designer</span>
      <span>Freelance</span>
    </div>
  </div>
</section>

<!-- Parallax script -->
<Parallax />

<style>
  /* ============================================
     HERO — text-centered with floating stickers
     Figma: 1512px wide artboard, padding 40px Y / 60px X
     ============================================ */
  .hero {
    background-color: var(--color-violet);
    padding: calc(200 * var(--unit)) var(--container-padding) calc(80 * var(--unit));
    overflow: hidden;
    position: relative;
    box-sizing: border-box;
  }

  .hero__inner {
    position: relative;
    /* Inner content area = 1392px wide in Figma (1512 - 60*2 padding) */
    max-width: calc(1392 * var(--unit));
    margin: 0 auto;
    width: 100%;
    /* Reserve space for stickers (image hero was 540px tall in Figma area;
       we keep ~620px so the stickers have room to spread around the title) */
    min-height: calc(620 * var(--unit));
    /* Center the text vertically in this space */
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: calc(2 * var(--unit));
  }

  /* Title — big LC Mogi text */
  .hero__title {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: var(--color-aubergine);
    text-align: center;
    position: relative;
    z-index: 10;
  }

  .hero__name {
    font-size: var(--text-display);
    letter-spacing: 0.05em;
    line-height: 1.2;
  }

  /* Meta line below the title */
  .hero__meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-5);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-aubergine);
    text-align: center;
    position: relative;
    z-index: 10;
  }

  /* ============================================
     STICKERS — positions from Figma 1512px artboard
     Reference inner area = 1392px wide.
     All fluid via var(--unit). z-index 5 so they sit behind text.
     ============================================ */
  .sticker {
    position: absolute;
    pointer-events: none;
    z-index: 5;
    height: auto;
    will-change: transform;
  }

  /* Etoile — LEFT side, slightly above center
     Figma: left 322, top 160, size 109px, rotation 19.32° */
  .sticker--etoile {
    top: calc(160 * var(--unit));
    left: calc(322 * var(--unit));
    width: calc(109 * var(--unit));
    transform: rotate(19.32deg);
  }

  /* Eyes — RIGHT side, slightly above center
     Figma: left 1066, top 160, size 133px wide, rotation -6.11° */
  .sticker--eyes {
    top: calc(160 * var(--unit));
    /* From left in Figma: 1066. From right in 1392 container: 1392-1066-133 = 193px */
    right: calc(193 * var(--unit));
    width: calc(133 * var(--unit));
    transform: rotate(-6.11deg);
  }

  /* Galaxy — LEFT side, bottom
     Figma: left 241, top 595, size 150x107 */
  .sticker--galaxy {
    top: calc(595 * var(--unit));
    left: calc(241 * var(--unit));
    width: calc(150 * var(--unit));
    transform: rotate(0deg);
  }

  /* Peace — RIGHT side, bottom
     Figma: approximate position based on container percentages */
  .sticker--peace {
    top: calc(630 * var(--unit));
    right: calc(280 * var(--unit));
    width: calc(110 * var(--unit));
    transform: rotate(24.81deg);
  }

  /* Planète — CENTER, bottom
     Figma: left 691, top 689, size 130x104, rotation -6.28° */
  .sticker--planete {
    top: calc(689 * var(--unit));
    left: calc(691 * var(--unit));
    width: calc(130 * var(--unit));
    transform: rotate(-6.28deg);
  }

  /* ============================================
     MOBILE
     ============================================ */
  @media (max-width: 768px) {
    .hero {
      padding: 133px var(--container-padding) 60px;
    }

    .hero__inner {
      min-height: auto;
    }

    .hero__name {
      font-size: 48px;
      letter-spacing: 2.4px;
    }

    .hero__meta {
      font-size: 16px;
    }

    /* Hide stickers on mobile for clean look */
    .sticker {
      display: none;
    }
  }
</style>
