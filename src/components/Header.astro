---
// Floating glassmorphism navigation header
---

<header class="header">
  <nav class="menu" aria-label="Navigation principale">
    <a href="/" class="menu__logo" aria-label="Accueil">
      <svg width="100%" height="100%" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="2"/>
        <path d="M24 0C35.1162 0 40.6748 0.000283658 44.2061 3.35645C44.3556 3.49855 44.5014 3.64444 44.6436 3.79395C47.9997 7.32515 48 12.8838 48 24C48 35.1162 47.9997 40.6748 44.6436 44.2061C44.5014 44.3556 44.3556 44.5014 44.2061 44.6436C40.6748 47.9997 35.1162 48 24 48C12.8838 48 7.32515 47.9997 3.79395 44.6436C3.64444 44.5014 3.49855 44.3556 3.35645 44.2061C0.000283658 40.6748 0 35.1162 0 24C0 12.8838 0.00028378 7.32515 3.35645 3.79395C3.49855 3.64444 3.64444 3.49855 3.79395 3.35645C7.32515 0.00028378 12.8838 0 24 0ZM18.9746 19.1104L11.4482 16.7939L17.1689 22.5127L6.2793 25.9756L17.1689 27.4248L13.8545 35.1787L20.7246 29.8809L23.1768 42.3096L26.2539 31.6865L35.3389 38.1074L29.9229 29.8809L40.5381 29.4248L31.4131 24.6729L39.6768 17.5391L29.5381 20.6787L31.6621 9.1543L24.1318 17.5391L19.8916 8.42773L18.9746 19.1104Z" fill="#C8F74D"/>
      </svg>
    </a>

    <ul class="menu__list">
      <li><a href="/projets">Projets</a></li>
      <!-- <li><a href="/a-propos">A propos</a></li> -->
      <li><a href="/ressources">Ressources</a></li>
      <li><a href="mailto:legallais.loick@gmail.com">Contact</a></li>
    </ul>
  </nav>
</header>

<style>
  /* DESKTOP */
  .header {
    position: fixed;
    top: calc(28 * var(--unit));
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    pointer-events: none;
  }

  .menu {
    pointer-events: auto;
    display: flex;
    align-items: center;
    gap: calc(28 * var(--unit));
    padding: var(--space-3) var(--space-4) var(--space-3) var(--space-3);
    background: #31243D;
    border-radius: var(--radius-lg);
    box-shadow: 0 8px 32px rgba(49, 36, 61, 0.08);
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .menu:hover {
    box-shadow: 0 12px 40px rgba(49, 36, 61, 0.15);
  }

  .menu__logo {
    display: flex;
    align-items: center;
    justify-content: center;
    width: calc(48 * var(--unit));
    height: calc(48 * var(--unit));
    min-width: 32px;
    min-height: 32px;
    color: var(--color-aubergine);
    transition: transform var(--transition-base);
  }

  .menu__logo:hover {
    transform: rotate(-8deg);
  }

  .menu__list {
    display: flex;
    align-items: center;
    gap: calc(28 * var(--unit));
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .menu__list a {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: #ffffff;
    position: relative;
    padding: var(--space-1) 0;
    transition: opacity var(--transition-base);
  }

  .menu__list a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -4px;
    height: 1px;
    width: 100%;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: right center;
    transition: transform var(--transition-base);
  }

  .menu__list a:hover::after {
    transform: scaleX(1);
    transform-origin: left center;
  }

  /* MOBILE — slightly more compact */
  @media (max-width: 768px) {
    .header {
      top: 16px;
      /* Add side margin so it never touches screen edges */
      max-width: calc(100vw - 32px);
      width: calc(100vw - 32px);
    }

    .menu {
      gap: 16px;
      padding: 10px 16px 10px 10px;
      width: 100%;
      justify-content: space-evenly; 
      border-radius: var(--radius-xl);
    }

    .menu__logo {
      width: 36px;
      height: 36px;
    }

    .menu__list {
      flex: 1;
    justify-content: space-evenly;
    gap: 0;
    }

    .menu__list a {
      font-size: 13px;
    }
  }
</style>
