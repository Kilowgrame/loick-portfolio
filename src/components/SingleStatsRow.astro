---
// Bottom stats row for single project pages.
// Same 3 stats are shown on every single (only when showStats=true).
// To change the numbers globally, edit the array below.

const stats = [
  { value: '7', label: 'ans d\'expériences' },
  { value: '+50', label: 'clients accompagnés' },
  { value: '+120', label: 'heures de formations données' },
];
---

<div class="single-stats">
  {stats.map((stat) => (
    <div class="single-stat">
      <p class="single-stat__value display">{stat.value}</p>
      <div class="single-stat__line"></div>
      <p class="single-stat__label">{stat.label}</p>
    </div>
  ))}
</div>

<style>
  .single-stats {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-10);
    width: 100%;
  }

  .single-stat {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    text-align: center;
  }

  .single-stat__value {
    font-size: var(--text-2xl);
    line-height: 1;
    color: var(--color-aubergine);
    margin: 0;
  }

  .single-stat__line {
    width: 100%;
    height: 1px;
    background: var(--color-aubergine);
    opacity: 0.3;
  }

  .single-stat__label {
    font-size: var(--text-base);
    color: var(--color-aubergine);
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .single-stats {
      flex-direction: column;
      gap: 64px;
    }

    .single-stat {
      width: 100%;
      align-items: flex-start;
      gap: 12px;
    }

    .single-stat__label {
      text-align: left;
    }
  }
</style>
