---
// Footer
---

<footer class="footer">
  <div class="footer__left">
    <a href="/" class="footer__logo" aria-label="Accueil">
      <svg width="100%" height="100%" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="2"/>
        <path d="M16 16 L16 32 M16 32 L32 32" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </a>

    <div class="footer__nav-wrap">
      <ul class="footer__nav">
        <li><a href="/projets">Projets</a></li>
        <li><a href="/a-propos">A propos</a></li>
        <li><a href="/ressources">Ressources</a></li>
        <li><a href="mailto:legallais.loick@gmail.com">Contact</a></li>
      </ul>
    </div>
  </div>

  <div class="footer__right">
    <a href="mailto:legallais.loick@gmail.com" class="footer__email">
      legallais.loick@gmail.com
    </a>

    <div class="footer__socials">
      <a href="https://www.linkedin.com/" target="_blank" rel="noopener noreferrer" class="tag">Linkedin</a>
      <a href="https://www.figma.com/" target="_blank" rel="noopener noreferrer" class="tag">Figma</a>
    </div>
  </div>
</footer>

<style>
  /* DESKTOP */
  .footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-8);
    padding: var(--space-6) var(--container-padding);
    background: var(--color-white);
    border-top: 1px solid var(--color-border-light);
    color: var(--color-aubergine);
  }

  .footer__left,
  .footer__right {
    display: flex;
    align-items: center;
    gap: var(--space-12);
    flex-wrap: wrap;
  }

  .footer__logo {
    display: flex;
    align-items: center;
    width: calc(48 * var(--unit));
    height: calc(48 * var(--unit));
    min-width: 32px;
    min-height: 32px;
    color: var(--color-aubergine);
    transition: transform var(--transition-base);
  }

  .footer__logo:hover {
    transform: rotate(-8deg);
  }

  .footer__nav-wrap {
    display: contents;
  }

  .footer__nav {
    display: flex;
    align-items: center;
    gap: var(--space-10);
    list-style: none;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
  }

  .footer__nav a,
  .footer__email {
    font-size: var(--text-sm);
    color: #000;
    transition: opacity var(--transition-base);
  }

  .footer__nav a:hover,
  .footer__email:hover {
    opacity: 0.6;
  }

  .footer__socials {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .footer__socials .tag {
    color: var(--color-aubergine);
    transition: background var(--transition-base), color var(--transition-base);
  }

  .footer__socials .tag:hover {
    background: var(--color-aubergine);
    color: var(--color-white);
  }

  /* MOBILE — Figma: padding 24px 20px, vertical stack */
  @media (max-width: 768px) {
    .footer {
      flex-direction: column;
      align-items: stretch;
      gap: 40px;
      padding: 24px var(--container-padding);
    }

    .footer__left {
      flex-direction: column;
      align-items: flex-start;
      gap: 40px;
      width: 100%;
    }

    .footer__logo {
      width: 48px;
      height: 48px;
    }

    .footer__nav-wrap {
      display: block;
      width: 100%;
    }

    .footer__nav {
      /* Figma: gap 24px 40px (vertical horizontal) */
      gap: 24px 40px;
      font-size: 16px;
    }

    .footer__nav a,
    .footer__email {
      font-size: 16px;
    }

    .footer__right {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
      width: 100%;
    }

    .footer__socials {
      /* Figma: gap 48px */
      gap: 48px;
    }
  }
</style>
